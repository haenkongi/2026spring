<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>한국 고생대 화석 아카이브 (Open Source)</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <style>
        :root {
            --primary-color: #2c3e50;
            --accent-color: #e67e22;
            --bg-color: #f4f7f6;
        }

        body {
            font-family: 'Pretendard', sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            background-color: var(--bg-color);
        }

        header {
            background-color: var(--primary-color);
            color: white;
            padding: 1rem 2rem;
            text-align: center;
        }

        main {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* 지도 영역 */
        #map {
            flex: 2;
            height: 100%;
        }

        /* 정보 패널 */
        #info-panel {
            flex: 1;
            padding: 2rem;
            background: white;
            box-shadow: -2px 0 5px rgba(0,0,0,0.1);
            overflow-y: auto;
            border-left: 1px solid #ddd;
        }

        .fossil-card {
            border-left: 5px solid var(--accent-color);
            padding-left: 15px;
            margin-bottom: 20px;
        }

        h2 { color: var(--primary-color); }
        .label { font-weight: bold; color: #555; }
        .placeholder { color: #999; text-align: center; margin-top: 50px; }

        footer {
            background: #ddd;
            text-align: center;
            padding: 0.5rem;
            font-size: 0.8rem;
        }
    </style>
</head>
<body>

<header>
    <h1>🇰🇷 한국 고생대 화석 아카이브</h1>
    <p>Open Source Geological Database</p>
</header>

<main>
    <div id="map"></div>
    
    <div id="info-panel">
        <div id="default-msg" class="placeholder">
            <h3>지도의 마커를 클릭하세요</h3>
            <p>해당 지역의 산출 화석 정보가 표시됩니다.</p>
        </div>
        <div id="fossil-content" style="display: none;">
            <h2 id="loc-title">지역명</h2>
            <div class="fossil-card">
                <p><span class="label">지층:</span> <span id="stratum">-</span></p>
                <p><span class="label">시대:</span> <span id="age">-</span></p>
                <p><span class="label">주요 화석:</span> <span id="fossil-name">-</span></p>
            </div>
            <p id="description">상세 설명이 여기에 들어갑니다.</p>
        </div>
    </div>
</main>

<footer>
    © 2026 Fossil Archive Project | Data provided for Academic Purposes
</footer>

<script>
    // 1. 지도 초기화 (한국 중심 좌표)
    const map = L.map('map').setView([37.2, 128.5], 9);

    // 2. 배경 지도 설정 (OpenStreetMap)
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap'
    }).addTo(map);

    // 3. 화석 데이터 (나중에 이 부분만 수정하거나 JSON에서 불러오면 됩니다)
    const fossilData = [
        {
            name: "영월군 영흥층",
            lat: 37.183,
            lng: 128.461,
            stratum: "영흥층 (Yeongheung Formation)",
            age: "중기 오르도비스기",
            fossil: "삼엽충, 완족류, 두족류",
            desc: "영흥층은 주로 석회암과 돌로마이트로 구성되어 있으며, 얕은 바다 환경에서 퇴적되었습니다."
        },
        {
            name: "태백시 직운산층",
            lat: 37.105,
            lng: 129.007,
            stratum: "직운산층 (Jigunsan Formation)",
            age: "중기 오르도비스기",
            fossil: "필석, 연체동물, 삼엽충",
            desc: "직운산층은 셰일층으로 유명하며, 매우 보존 상태가 좋은 다양한 무척추동물 화석이 발견됩니다."
        }
    ];

    // 4. 지도에 마커 찍기 및 클릭 이벤트
    fossilData.forEach(item => {
        const marker = L.marker([item.lat, item.lng]).addTo(map);
        
        marker.on('click', () => {
            // 정보 패널 내용 업데이트
            document.getElementById('default-msg').style.display = 'none';
            document.getElementById('fossil-content').style.display = 'block';
            
            document.getElementById('loc-title').innerText = item.name;
            document.getElementById('stratum').innerText = item.stratum;
            document.getElementById('age').innerText = item.age;
            document.getElementById('fossil-name').innerText = item.fossil;
            document.getElementById('description').innerText = item.desc;
        });
    });
</script>

</body>
</html>
